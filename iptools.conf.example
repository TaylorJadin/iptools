# iptools config
#
# This file is loaded from the same directory as the iptools executable.
# Overrides are also loaded from:
#   ~/.config/iptools/config
#   $IPTOOLS_CONFIG
#   --config PATH
#
# Later files override boolean options. Skip entries are cumulative.

# Skip the device's public IP address in command output.
skip_public_ip = true 

[skip]
# Add IP addresses, CIDR ranges, or ASNs to skip, one per line.
# Examples:
# 203.0.113.10
# 198.51.100.0/24
# 2001:db8::/32
# AS13335 

# Some Bogon IP ranges you probably want to skip (from https://ipinfo.io/bogon)
0.0.0.0/8 # "This" network
10.0.0.0/8 # Private-use networks
100.64.0.0/10 # Carrier-grade NAT
127.0.0.0/8 # Loopback
127.0.53.53 # Name collision occurrence
169.254.0.0/16 # Link local
172.16.0.0/12 # Private-use networks
192.0.0.0/24 # IETF protocol assignments
192.0.2.0/24 # TEST-NET-1
192.168.0.0/16 # Private-use networks
198.18.0.0/15 # Network interconnect device benchmark testing
198.51.100.0/24 # TEST-NET-2
203.0.113.0/24 # TEST-NET-3
224.0.0.0/4 # Multicast
240.0.0.0/4 # Reserved for future use
255.255.255.255/32 # Limited broadcast
::/128 # Node-scope unicast unspecified address
::1/128 # Node-scope unicast loopback address
::ffff:0:0/96 # IPv4-mapped addresses
::/96 # IPv4-compatible addresses
100::/64 # Remotely triggered black hole addresses
2001:10::/28 # Overlay routable cryptographic hash identifiers (ORCHID)
2001:db8::/32 # Documentation prefix
3fff::/20 # Documentation prefix
fc00::/7 # Unique local addresses (ULA)
fe80::/10 # Link-local unicast
fec0::/10 # Site-local unicast (deprecated)
ff00::/8 # Multicast (Note: ff0e:/16 is global scope and may appear on the global internet.)
