#!/usr/bin/env python3

"""
Identify common IPs, ASNs, and CIDR prefixes from IP addresses found in input.

Examples:
  ipcondense 1.1.1.1 8.8.8.8
  ipcondense ips.txt
  ipcondense 'client=192.0.2.1 peer=2001:db8::1'
  curl -s https://api.github.com/meta | ipcondense --cidr --short
  ipcondense --ip --min-count 2 access.log
"""

import argparse
import ipaddress
import os
import re
import socket
import sys
from collections import Counter
from typing import List, Tuple

IP_RE = re.compile(r"\b(?:\d{1,3}\.){3}\d{1,3}\b|\b[0-9a-fA-F:]+:[0-9a-fA-F:]*\b")


def is_valid_ip(value):
    # type: (str) -> bool
    try:
        ipaddress.ip_address(value)
        return True
    except ValueError:
        return False


def extract_ips(text):
    # type: (str) -> List[str]
    """Pull valid IP addresses out of an arbitrary blob of text."""
    return [match for match in IP_RE.findall(text) if is_valid_ip(match)]


def collect_inputs(inputs):
    # type: (List[str]) -> List[str]
    """Build a list of IPs from args, files, arbitrary text, and stdin."""
    ips = []  # type: List[str]

    for item in inputs:
        if os.path.isfile(item):
            with open(item, "r") as handle:
                ips.extend(extract_ips(handle.read()))
            continue

        ips.extend(extract_ips(item))

    if not sys.stdin.isatty():
        ips.extend(extract_ips(sys.stdin.read()))

    return ips


def filter_ips(ips, include_ipv4, include_ipv6):
    # type: (List[str], bool, bool) -> List[str]
    """Filter IPs by address family."""
    filtered = []  # type: List[str]
    for ip in ips:
        parsed = ipaddress.ip_address(ip)
        if isinstance(parsed, ipaddress.IPv4Address) and include_ipv4:
            filtered.append(ip)
        elif isinstance(parsed, ipaddress.IPv6Address) and include_ipv6:
            filtered.append(ip)
    return filtered


def unique_items(items):
    # type: (List[str]) -> List[str]
    """Deduplicate while preserving order."""
    seen = set()
    unique = []  # type: List[str]
    for item in items:
        if item in seen:
            continue
        seen.add(item)
        unique.append(item)
    return unique


def lookup_bulk(ips):
    # type: (List[str]) -> List[Tuple[str, str, str, str]]
    """Query Team Cymru bulk WHOIS."""
    query = "begin\nverbose\n" + "\n".join(ips) + "\nend\n"
    with socket.create_connection(("whois.cymru.com", 43), timeout=30) as s:
        s.sendall(query.encode())
        chunks = []  # type: List[bytes]
        while True:
            chunk = s.recv(4096)
            if not chunk:
                break
            chunks.append(chunk)
        data = b"".join(chunks)

    results = []  # type: List[Tuple[str, str, str, str]]
    for line in data.decode().splitlines()[1:]:  # skip header
        parts = [p.strip() for p in line.split("|")]
        if len(parts) >= 7:
            asn, ip, prefix, cc, _, _, name = parts[:7]
            if asn == "NA" or prefix == "NA":
                continue
            results.append((asn, prefix, cc, name))
    return results


def main():
    # type: () -> int
    parser = argparse.ArgumentParser(
        description="Identify common IPs, ASNs, and CIDR prefixes from a set of IPs.",
    )
    parser.add_argument(
        "inputs",
        nargs="*",
        help="IP addresses, file paths, or arbitrary text containing IPs",
    )
    parser.add_argument(
        "-4", "--ipv4",
        action="store_true",
        help="Include IPv4 addresses. Combine with -6 (or omit both) for all.",
    )
    parser.add_argument(
        "-6", "--ipv6",
        action="store_true",
        help="Include IPv6 addresses. Combine with -4 (or omit both) for all.",
    )
    parser.add_argument(
        "-n", "--top",
        type=int,
        default=None,
        help="Show top N entries (default: 10, "
             "or all when --min-count is used without -n)",
    )
    parser.add_argument(
        "-a", "--all",
        action="store_true",
        help="Show all entries (overrides --top)",
    )
    parser.add_argument(
        "-m", "--min-count",
        type=int,
        default=0,
        metavar="N",
        help="Only show entries with at least N IPs "
             "(implies --all unless -n is also given)",
    )
    parser.add_argument(
        "--asn",
        action="store_true",
        help="Only output the ASN section",
    )
    parser.add_argument(
        "--ip",
        action="store_true",
        help="Only output the IP address section",
    )
    parser.add_argument(
        "--cidr",
        action="store_true",
        help="Only output the CIDR section",
    )
    parser.add_argument(
        "--short",
        action="store_true",
        help="Output only the IPs, ASNs, or CIDR ranges, one per line (no headers or counts)",
    )
    parser.add_argument(
        "--unique",
        action="store_true",
        help="Deduplicate discovered IPs before lookup",
    )
    args = parser.parse_args()

    include_ipv4 = args.ipv4 or not (args.ipv4 or args.ipv6)
    include_ipv6 = args.ipv6 or not (args.ipv4 or args.ipv6)

    ips = collect_inputs(args.inputs)
    ips = filter_ips(ips, include_ipv4, include_ipv6)
    if args.unique:
        ips = unique_items(ips)
    if not ips:
        parser.error("no IPs provided; pass IPs/files/text as arguments or pipe via stdin")

    # If none of the section flags are set, show all sections.
    show_ip = args.ip or not (args.ip or args.asn or args.cidr)
    show_asn = args.asn or not (args.ip or args.asn or args.cidr)
    show_cidr = args.cidr or not (args.ip or args.asn or args.cidr)

    threshold = args.min_count

    # Limit the output:
    # --all wins; otherwise -n if given; otherwise default to all when
    # --min-count is used (so the threshold filter is meaningful), else top 10.
    if args.all:
        limit = None
    elif args.top is not None:
        limit = args.top
    elif threshold > 0:
        limit = None
    else:
        limit = 10

    def filtered(counter):
        items = counter.most_common(None if limit is None else limit)
        if threshold > 0:
            items = [(k, c) for k, c in items if c >= threshold]
        return items

    ip_counter = Counter(ips)
    results = []  # type: List[Tuple[str, str, str, str]]
    if show_asn or show_cidr:
        try:
            results = lookup_bulk(ips)
        except (socket.timeout, OSError) as exc:
            print("error: lookup: {}".format(exc), file=sys.stderr)
            return 1

    asn_counter = Counter((r[0], r[3]) for r in results)
    cidr_counter = Counter((r[1], r[0], r[3]) for r in results)

    if limit is None:
        scope_label = "all"
    else:
        scope_label = "top {}".format(limit)
    if threshold > 0:
        scope_label += ", >={} IPs".format(threshold)

    if args.short:
        if show_ip:
            for ip, _count in filtered(ip_counter):
                print(ip)
        if show_cidr:
            for (cidr, _asn, _name), _count in filtered(cidr_counter):
                print(cidr)
        if show_asn:
            for (asn, _name), _count in filtered(asn_counter):
                print("AS{}".format(asn))
        return 0

    if show_asn or show_cidr:
        print("\n{} IPs total, {} resolved".format(len(ips), len(results)))
    else:
        print("\n{} IPs total".format(len(ips)))

    if show_ip:
        print("\n=== IPs ({}) ===".format(scope_label))
        for ip, count in filtered(ip_counter):
            print("  {:>5}  {}".format(count, ip))

    if show_cidr:
        print("\n=== CIDR Prefixes ({}) ===".format(scope_label))
        for (cidr, asn, name), count in filtered(cidr_counter):
            print("  {:>5}  {:<20}  AS{:<8}  {}".format(count, cidr, asn, name))

    if show_asn:
        print("\n=== ASNs ({}) ===".format(scope_label))
        for (asn, name), count in filtered(asn_counter):
            print("  {:>5}  AS{:<8}  {}".format(count, asn, name))

    return 0


if __name__ == "__main__":
    sys.exit(main())
